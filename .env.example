# ---------------------------------------------------------------------------
# MasterMind: Story Builder — Environment Variables
# ---------------------------------------------------------------------------
# 1. Copy this file to a new file named `.env` (in the same folder).
# 2. Fill in the two values below from your Supabase dashboard.
# 3. Save. Never commit `.env` to git — `.gitignore` already blocks it.
# ---------------------------------------------------------------------------

# Your Supabase project's base URL.
# Example: https://abcdefghij.supabase.co
# Where to find it: it's the first part of any URL Supabase gives you,
# e.g. the Data API URL minus the trailing /rest/v1/.
VITE_SUPABASE_URL=

# Your Supabase "publishable" API key (also shown as "anon public" in the
# legacy UI). This one is safe to ship in frontend code.
# Where to find it: Supabase dashboard → Project Settings → API Keys → "Publishable key"
# DO NOT use the "secret" or "service_role" key here.
VITE_SUPABASE_ANON_KEY=
